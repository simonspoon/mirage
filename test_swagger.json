{
  "swagger": "2.0",
  "info": {
    "title": "Medical API",
    "version": "1.0"
  },
  "paths": {
    "/api/composite/hospitallist/gethospitallistpatients": {
      "get": {
        "operationId": "getHospitalListPatients",
        "summary": "Get hospital list patients",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/HospitalListDto"
              }
            }
          }
        }
      }
    },
    "/api/patient/{patientId}": {
      "get": {
        "operationId": "getPatient",
        "summary": "Get patient by ID",
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/PatientDto"
            }
          }
        }
      }
    },
    "/api/user/profile": {
      "get": {
        "operationId": "getUserProfile",
        "summary": "Get user profile",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/UserProfileDto"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "BaseEntityDto": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "createdDate": {"type": "string", "format": "date-time"},
        "modifiedDate": {"type": "string", "format": "date-time"}
      },
      "required": ["id"]
    },
    "PersonDto": {
      "type": "object",
      "properties": {
        "firstName": {"type": "string"},
        "lastName": {"type": "string"},
        "dateOfBirth": {"type": "string", "format": "date"}
      }
    },
    "HospitalListDto": {
      "allOf": [
        {"$ref": "#/definitions/BaseEntityDto"},
        {
          "type": "object",
          "properties": {
            "patientName": {"type": "string"},
            "ward": {"type": "string"},
            "admissionDate": {"type": "string", "format": "date-time"},
            "status": {
              "type": "string",
              "enum": ["admitted", "discharged", "transferred"]
            }
          }
        }
      ]
    },
    "PatientDto": {
      "allOf": [
        {"$ref": "#/definitions/BaseEntityDto"},
        {"$ref": "#/definitions/PersonDto"},
        {
          "type": "object",
          "properties": {
            "medicalRecordNumber": {"type": "string"},
            "insuranceProvider": {"type": "string"}
          }
        }
      ]
    },
    "CadabraUserDto": {
      "type": "object",
      "properties": {
        "userId": {"type": "integer"},
        "username": {"type": "string"},
        "email": {"type": "string"}
      }
    },
    "UserProfileDto": {
      "type": "object",
      "properties": {
        "displayName": {"type": "string"},
        "entryUser": {
          "allOf": [{"$ref": "#/definitions/CadabraUserDto"}]
        },
        "role": {"type": "string"}
      }
    },
    "TestModel": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "values": {"type": "string"},
        "key": {"type": "string"},
        "order": {"type": "integer"},
        "name": {"type": "string"}
      }
    }
  }
}
